<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.atguigu.lease.web.admin.mapper.FeeKeyMapper">

    <resultMap id="FeeVOMap" type="com.atguigu.lease.web.admin.vo.fee.FeeKeyVo" autoMapping="true">
        <id column="id" property="id"/>
        <collection property="feeValueList" ofType="com.atguigu.lease.model.entity.FeeValue" autoMapping="true">
            <id column="fee_valu_id" property="id"/>
            <result column="fee_valu_name" property="name"/>
        </collection>
    </resultMap>
    <select id="feeInfoList" resultMap="FeeVOMap">
        select k.id,
               k.name,
               v.id   fee_valu_id,
               v.name fee_valu_name,
               v.unit,
               v.fee_key_id
        from fee_key k
                 left join fee_value v on k.id = v.fee_key_id and v.is_deleted = 0
        where k.is_deleted = 0;
    </select>
</mapper>
